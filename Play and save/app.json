{
    "expo": {
        "name": "Play & Save",
        "slug": "play-and-save",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "scheme": "playandsave",
        "userInterfaceStyle": "dark",
        "newArchEnabled": true,
        "splash": {
            "backgroundColor": "#0D1117"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.playandsave.app"
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#0D1117"
            },
            "package": "com.playandsave.app"
        },
        "web": {
            "bundler": "metro",
            "output": "single",
            "favicon": "./assets/favicon.png"
        },
        "plugins": [
            "expo-router"
        ]
    }
}